# ===== Using Docker (recommended) =====
# Copy this file to .env in the project root and fill in your values.
# Then run: docker-compose up

# ===== Running locally (without Docker) =====
# Same file — just update DATABASE_URL to point to your local PostgreSQL.

# PostgreSQL (used by docker-compose and the db container)
POSTGRES_DB=KashifDB
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Flask
# Docker: use @db:5432  |  Local: use @localhost:5432
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/KashifDB
SECRET_KEY=change-me-in-production
FLASK_ENV=development
